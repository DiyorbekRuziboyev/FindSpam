# Auto-detect text files and enforce LF in repository
* text=auto eol=lf

# Force LF for all source files
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.css text eol=lf
*.conf text eol=lf
*.sh text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf
*.Dockerfile text eol=lf
.env.example text eol=lf
.gitignore text eol=lf
.prettierrc text eol=lf

# Binary — no LF conversion
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pt binary
*.pth binary
*.bin binary
*.onnx binary
