{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@findspam/types": ["../../packages/types/src/index.ts"],
      "@findspam/ui": ["../../packages/ui/src/index.ts"],
      "@findspam/utils": ["../../packages/utils/src/index.ts"]
    }
  }
}
