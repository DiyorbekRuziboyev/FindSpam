# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=FindSpam
APP_VERSION=1.0.0
DEBUG=true

# ─── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_NAME=FindSpam

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=findspam
POSTGRES_USER=findspam_user
POSTGRES_PASSWORD=changeme_strong_password
DATABASE_URL=postgresql+asyncpg://findspam_user:changeme_strong_password@localhost:5432/findspam

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password
REDIS_URL=redis://:changeme_redis_password@localhost:6379/0

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY_PATH=./infrastructure/keys/private.pem
JWT_PUBLIC_KEY_PATH=./infrastructure/keys/public.pem
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/v1/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=changeme_webhook_secret

# ─── AI Engine ────────────────────────────────────────────────────────────────
AI_ENGINE_HOST=localhost
AI_ENGINE_PORT=8001
AI_MODEL_PATH=./apps/ai-engine/model_artifacts
AI_CONFIDENCE_THRESHOLD_SPAM=0.80
AI_CONFIDENCE_THRESHOLD_SUSPICIOUS=0.60
AI_CONFIDENCE_THRESHOLD_REVIEW=0.30
AI_BATCH_SIZE=32
AI_MAX_SEQ_LENGTH=512

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_LOGIN_PER_15MIN=5
RATE_LIMIT_API_PER_MINUTE=100
RATE_LIMIT_AI_PER_MINUTE=500

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=changeme_secret_key_min_32_chars_long
ALLOWED_HOSTS=localhost,127.0.0.1
